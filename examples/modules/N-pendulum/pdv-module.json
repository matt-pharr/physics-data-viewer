{
  "schema_version": "3",
  "id": "n_pendulum",
  "name": "N-Pendulum",
  "version": "2.0.0",
  "description": "A general N-link pendulum simulator. Supports double, triple, quadruple, and higher-order chaotic pendulums with ODE integration and animated visualization.",
  "entry_point": "n_pendulum",
  "compatibility": {
    "pdv_min": "0.1.0",
    "pdv_max": "99.0.0",
    "python": ">=3.10,<3.14",
    "python_min": "3.10.0",
    "python_max": "3.13.99"
  },
  "dependencies": [
    { "name": "numpy", "version": ">=1.24" },
    { "name": "scipy", "version": ">=1.10" },
    { "name": "matplotlib", "version": ">=3.7" },
    { "name": "PyQt6", "version": ">=6.5" },
    { "name": "ffmpeg", "marker": "optional external binary for video export" }
  ],
  "scripts": [
    { "name": "solve", "path": "scripts/solve.py" },
    { "name": "animate", "path": "scripts/animate.py" }
  ],
  "files": [
    { "name": "solver_nml", "path": "inputs/solver.nml", "type": "namelist" }
  ]
}
