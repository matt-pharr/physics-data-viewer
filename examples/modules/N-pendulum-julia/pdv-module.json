{
  "schema_version": "3",
  "id": "n_pendulum_julia",
  "name": "N-Pendulum (Julia)",
  "version": "2.0.0",
  "language": "julia",
  "description": "A general N-link pendulum simulator in Julia. Supports double, triple, quadruple, and higher-order chaotic pendulums with ODE integration and animated visualization.",
  "entry_point": "NPendulum",
  "compatibility": {
    "pdv_min": "0.1.0",
    "pdv_max": "99.0.0",
    "julia": ">=1.10"
  },
  "dependencies": [
    { "name": "DifferentialEquations", "version": ">=7.0" },
    { "name": "LinearAlgebra", "marker": "stdlib" },
    { "name": "CairoMakie", "version": ">=0.10", "marker": "optional, for plotting" }
  ],
  "scripts": [
    { "name": "solve", "path": "scripts/solve.jl" },
    { "name": "animate", "path": "scripts/animate.jl" }
  ],
  "files": [
    { "name": "solver_nml", "path": "inputs/solver.nml", "type": "namelist" }
  ]
}
