{
  "name": "physics-data-viewer",
  "version": "0.0.6",
  "private": true,
  "main": "dist/main/bootstrap.js",
  "electronmon": {
    "patterns": [
      "!dist/**"
    ]
  },
  "scripts": {
    "dev": "node ./node_modules/concurrently/dist/bin/concurrently.js -k \"npm:dev:main\" \"npm:dev:renderer\"",
    "dev:main": "node ./node_modules/cross-env/src/bin/cross-env.js NODE_ENV=development node ./node_modules/electronmon/bin/cli.js .",
    "dev:renderer": "cd renderer && node ../node_modules/vite/bin/vite.js",
    "generate:icon:mac": "sh ./scripts/generate-mac-icon.sh",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "cd renderer && node ../node_modules/vite/bin/vite.js build",
    "build:main": "node ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "lint": "eslint .",
    "knip": "knip"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/katex": "^0.16.8",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^35.7.5",
    "electronmon": "^2.0.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^28.1.0",
    "knip": "^5.85.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.2.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "ansi-to-html": "^0.7.2",
    "katex": "^0.16.38",
    "marked": "^17.0.4",
    "marked-katex-extension": "^5.1.7",
    "monaco-editor": "^0.45.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zeromq": "^6.5.0"
  }
}
