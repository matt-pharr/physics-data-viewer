{
  "name": "physics-data-viewer",
  "version": "0.0.2",
  "private": true,
  "main": "dist/main/bootstrap.js",
  "electronmon": {
    "patterns": [
      "!dist/**"
    ]
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:main\" \"npm:dev:renderer\"",
    "dev:main": "cross-env NODE_ENV=development electronmon .",
    "dev:renderer": "cd renderer && vite",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "cd renderer && vite build",
    "build:main": "tsc -p tsconfig.json",
    "test": "node ./node_modules/vitest/vitest.mjs run --pool=forks",
    "lint": "echo \"Add eslint if desired\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electronmon": "^2.0.2",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "ansi-to-html": "^0.7.2",
    "monaco-editor": "^0.45.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zeromq": "^6.5.0"
  }
}
