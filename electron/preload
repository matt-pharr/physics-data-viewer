import { contextBridge, ipcRenderer } from 'electron';
import { IPC, KernelExecuteRequest, KernelExecuteResult, TreeNode, Config } from './main/ipc';

const api = {
  kernels: {
    list: (): Promise<Array<{ id:  string; language: string }>> =>
      ipcRenderer.invoke(IPC.kernels.list),
    start: (spec?: { language?: string }): Promise<{ id: string }> =>
      ipcRenderer.invoke(IPC.kernels.start, spec),
    stop: (id: string): Promise<boolean> =>
      ipcRenderer.invoke(IPC.kernels.stop, id),
    execute: (id: string, req: KernelExecuteRequest): Promise<KernelExecuteResult> =>
      ipcRenderer.invoke(IPC.kernels.execute, id, req),
    interrupt: (id: string): Promise<boolean> =>
      ipcRenderer.invoke(IPC.kernels.interrupt, id),
    restart: (id: string): Promise<boolean> =>
      ipcRenderer.invoke(IPC.kernels.restart, id),
    complete: (
      id: string,
      code: string,
      cursorPos: number
    ): Promise<{ matches: string[]; cursor_start: number; cursor_end:  number }> =>
      ipcRenderer.invoke(IPC.kernels.complete, id, code, cursorPos),
    inspect: (
      id: string,
      code: string,
      cursorPos: number
    ): Promise<{ found: boolean; data?: Record<string, string> }> =>
      ipcRenderer. invoke(IPC.kernels. inspect, id, code, cursorPos),
  },
  tree: {
    list: (path: string = ''): Promise<TreeNode[]> =>
      ipcRenderer.invoke(IPC.tree.list, path),
    get: (id: string): Promise<unknown> =>
      ipcRenderer. invoke(IPC.tree.get, id),
    save: (id: string, payload: unknown): Promise<boolean> =>
      ipcRenderer.invoke(IPC. tree.save, id, payload),
  },
  files: {
    read: (
      path: string,
      opts?:  { start?: number; end?: number }
    ): Promise<ArrayBuffer | string | null> =>
      ipcRenderer.invoke(IPC.files.read, path, opts),
    write: (path: string, content: string | Buffer): Promise<boolean> =>
      ipcRenderer.invoke(IPC.files.write, path, content),
  },
  config: {
    get: (): Promise<Config> =>
      ipcRenderer.invoke(IPC.config.get),
    set: (cfg:  Partial<Config>): Promise<boolean> =>
      ipcRenderer. invoke(IPC.config.set, cfg),
  },
};

contextBridge.exposeInMainWorld('pdv', api);

// Type declaration for renderer
declare global {
  interface Window {
    pdv: typeof api;
  }
}